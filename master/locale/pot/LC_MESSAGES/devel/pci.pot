#: ../../../../include/hw/pci/pci.h:411
msgid "callbacks structure for specific IOMMU handlers of a PCIBus"
msgstr ""

#: ../../../../include/hw/pci/pci.h:415
msgid "**Definition**::"
msgstr ""

#: ../../../../include/hw/pci/pci.h:417
msgid ""
"struct PCIIOMMUOps {\n"
"    bool (*supports_address_space)(PCIBus *bus, void *opaque, int devfn, "
"Error **errp);\n"
"    AddressSpace * (*get_address_space)(PCIBus *bus, void *opaque, int "
"devfn);\n"
"    bool (*set_iommu_device)(PCIBus *bus, void *opaque, int devfn, "
"HostIOMMUDevice *dev, Error **errp);\n"
"    void (*unset_iommu_device)(PCIBus *bus, void *opaque, int devfn);\n"
"    uint64_t (*get_viommu_flags)(void *opaque);\n"
"    uint64_t (*get_host_iommu_quirks)(uint32_t type, void *caps, uint32_t "
"size);\n"
"    void (*get_iotlb_info)(void *opaque, uint8_t *addr_width, uint32_t "
"*min_page_size);\n"
"    void (*init_iotlb_notifier)(PCIBus *bus, void *opaque, int devfn, "
"IOMMUNotifier *n, IOMMUNotify fn, void *user_opaque);\n"
"    void (*register_iotlb_notifier)(PCIBus *bus, void *opaque, int devfn, "
"uint32_t pasid, IOMMUNotifier *n);\n"
"    void (*unregister_iotlb_notifier)(PCIBus *bus, void *opaque, int devfn, "
"uint32_t pasid, IOMMUNotifier *n);\n"
"    ssize_t (*ats_request_translation)(PCIBus *bus, void *opaque, int devfn, "
"uint32_t pasid, bool priv_req, bool exec_req, hwaddr addr, size_t length, "
"bool no_write, IOMMUTLBEntry *result, size_t result_length, uint32_t "
"*err_count);\n"
"    void (*pri_register_notifier)(PCIBus *bus, void *opaque, int devfn, "
"uint32_t pasid, IOMMUPRINotifier *notifier);\n"
"    void (*pri_unregister_notifier)(PCIBus *bus, void *opaque, int devfn, "
"uint32_t pasid);\n"
"    int (*pri_request_page)(PCIBus *bus, void *opaque, int devfn, uint32_t "
"pasid, bool priv_req, bool exec_req, hwaddr addr, bool lpig, uint16_t prgi, "
"bool is_read, bool is_write);\n"
"    uint64_t (*get_msi_direct_gpa)(PCIBus *bus, void *opaque, int devfn);\n"
"};"
msgstr ""

