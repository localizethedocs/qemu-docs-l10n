#: ../../../specs/riscv-aia.rst:85
msgid "KVM accel option 'riscv-aia'"
msgstr ""

#: ../../../specs/riscv-aia.rst:87
msgid ""
"The KVM accelerator property 'riscv-aia' interacts with the \"aia=aplic-"
"imsic\" to determine how the host KVM module will provide the in-kernel "
"IMSIC s-mode controller.  The 'kernel-irqchip' setting has no impact in "
"'riscv-aia' given that any available 'kernel-irqchip' setting will always "
"have an in-kernel IMSIC s-mode.  'riscv-aia' has no impact in APLIC m-mode/s-"
"mode and IMSIC m-mode settings."
msgstr ""

