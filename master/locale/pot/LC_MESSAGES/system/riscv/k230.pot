#: ../../../system/riscv/k230.rst:2
msgid "Kendryte K230 virt reference platform (``k230``)"
msgstr ""

#: ../../../system/riscv/k230.rst:3
msgid "The ``k230`` machine is compatible with the Kendryte K230 SDK."
msgstr ""

#: ../../../system/riscv/k230.rst:5
msgid ""
"The K230 is a chip from the AIoT SoC series made by Kendryte ® — a part of "
"Canaan Inc. It uses a brand-new multi-heterogeneous unit accelerated "
"computing structure."
msgstr ""

#: ../../../system/riscv/k230.rst:9
msgid ""
"This chip has 2 RISC-V computing cores and a new-generation KPU (Knowledge "
"Process Unit) smart computing unit."
msgstr ""

#: ../../../system/riscv/k230.rst:12
msgid "For more information, see <https://www.kendryte.com/en/proDetail/230>"
msgstr ""

