#: ../../../system/nitro.rst:23
msgid "Quick Start"
msgstr ""

#: ../../../system/nitro.rst:25
msgid "Launch a Nitro Enclave from a pre-built EIF file::"
msgstr ""

#: ../../../system/nitro.rst:27
msgid ""
"$ qemu-system-x86_64 -accel nitro,debug-mode=on -M nitro -nographic \\\n"
"    -smp 2 -m 512M -kernel enclave.eif"
msgstr ""

#: ../../../system/nitro.rst:30
msgid "Launch an enclave from individual kernel and initrd files::"
msgstr ""

#: ../../../system/nitro.rst:32
msgid ""
"$ qemu-system-x86_64 -accel nitro,debug-mode=on -M nitro -nographic \\\n"
"    -smp 2 -m 512M -kernel vmlinuz -initrd initrd.cpio \\\n"
"    -append \"console=ttyS0\""
msgstr ""

#: ../../../system/nitro.rst:36
msgid ""
"The same commands work with ``qemu-system-aarch64`` on Graviton based EC2 "
"instances."
msgstr ""

