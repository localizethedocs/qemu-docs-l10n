msgstr ""

#: ../../../interop/vhost-user.rst:460 ../../../interop/vhost-user.rst:1209
msgid "``VHOST_USER_SET_MEM_TABLE``"
msgstr ""

#: ../../../interop/vhost-user.rst:462 ../../../interop/vhost-user.rst:1246
msgid "``VHOST_USER_SET_LOG_FD``"
msgstr ""

#: ../../../interop/vhost-user.rst:463 ../../../interop/vhost-user.rst:1335
