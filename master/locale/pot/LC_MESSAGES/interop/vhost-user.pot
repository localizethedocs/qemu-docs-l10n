msgstr ""

#: ../../../interop/vhost-user.rst:1495
msgid "``VHOST_USER_GET_CONFIG``"
msgstr ""

#: ../../../interop/vhost-user.rst:1496
msgid "24"
msgstr ""

#: ../../../interop/vhost-user.rst:1498 ../../../interop/vhost-user.rst:1499
