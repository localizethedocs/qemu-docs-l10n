#: ../../../system/qemu-colo.rst:311
msgid ""
"{\"execute\": \"stop\"}\n"
"{\"execute\": \"block-job-cancel\", \"arguments\":{ \"device\": "
"\"resync\"} }\n"
"\n"
"{\"execute\": \"blockdev-add\", \"arguments\": {\"driver\": \"nbd\", \"node-"
"name\": \"nbd0\", \"server\": {\"type\": \"inet\", \"host\": \"127.0.0.2\", "
"\"port\": \"9999\"}, \"export\": \"parent0\", \"detect-zeroes\": \"on\"} }\n"
"{\"execute\": \"x-blockdev-change\", \"arguments\":{ \"parent\": \"colo-"
"disk0\", \"node\": \"nbd0\" } }\n"
"\n"
"{\"execute\": \"object-add\", \"arguments\":{ \"qom-type\": \"filter-"
"mirror\", \"id\": \"m0\", \"netdev\": \"hn0\", \"queue\": \"tx\", "
