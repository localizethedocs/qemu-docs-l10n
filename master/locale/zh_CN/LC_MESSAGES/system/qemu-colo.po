"{\"execute\": \"object-add\", \"arguments\":{ \"qom-type\": \"filter-"
"redirector\", \"id\": \"redire0\", \"netdev\": \"hn0\", \"queue\": \"rx\", "
"\"indev\": \"compare_out\" } }\n"
"{\"execute\": \"object-add\", \"arguments\":{ \"qom-type\": \"filter-"
"redirector\", \"id\": \"redire1\", \"netdev\": \"hn0\", \"queue\": \"rx\", "
"\"outdev\": \"compare0\" } }\n"
"{\"execute\": \"object-add\", \"arguments\":{ \"qom-type\": \"iothread\", "
"\"id\": \"iothread1\" } }\n"
"{\"execute\": \"object-add\", \"arguments\":{ \"qom-type\": \"colo-"
"compare\", \"id\": \"comp0\", \"primary_in\": \"compare0-0\", "
"\"secondary_in\": \"compare1\", \"outdev\": \"compare_out0\", \"iothread\": "
"\"iothread1\" } }\n"
"\n"
"{\"execute\": \"migrate-set-capabilities\", \"arguments\":"
"{ \"capabilities\": [ {\"capability\": \"x-colo\", \"state\": true } ] } }\n"
"{\"execute\": \"migrate\", \"arguments\":{ \"uri\": "
"\"tcp:127.0.0.2:9998\" } }"
